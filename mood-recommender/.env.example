# ─────────────────────────────────────────────
#  Mood-Adaptive Recommender — Environment Keys
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# TMDB API — movie/show metadata, genres, overviews, cast, keywords
# Get key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDB API — IMDb ratings, plot summaries, awards, runtime
# Get key at: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# RapidAPI — Streaming Availability (Netflix, Prime, Disney+ catalog)
# Subscribe at: https://rapidapi.com/movie-of-the-night-movie-of-the-night-default/api/streaming-availability
RAPIDAPI_KEY=

# TVmaze REST API — TV show details, genres, network info (no key needed)
TVMAZE_BASE_URL=https://api.tvmaze.com

# Google Gemini API — LLM calls for mood interpretation and recommendation generation
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
